# Copy to .env.local and fill in. Optional for local dev:
# without VITE_API_URL the app runs on mock data.
#
# The map uses OpenStreetMap via Leaflet and needs NO API key.

# Node backend base URL, e.g. https://localhost:3000 (must be https:// when
# the frontend runs on https:// — browsers won't send Secure session cookies
# to an http:// origin).
VITE_API_URL=

# Python ML service (Grounding DINO) base URL for the Analyze page.
# Defaults to http://localhost:5001 if unset.
VITE_ML_URL=
