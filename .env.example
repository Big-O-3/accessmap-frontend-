# Copy to .env.local for dev, or set these in your host (Render / Vercel / etc.)
# for prod. All frontend traffic goes through the backend — the browser never
# talks to the ML service directly.

# Node backend base URL.
#   dev:  http://localhost:3000
#   prod: https://accessmap-backend.onrender.com   (no trailing slash)
VITE_API_URL=

# Supabase project — from Settings → API. The anon key is public by design
# and safe to ship in the frontend bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
