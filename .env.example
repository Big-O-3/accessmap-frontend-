# Copy to .env.local and fill in.

# Node backend base URL. In dev: http://localhost:3000
VITE_API_URL=

# Python ML service (Grounding DINO) base URL for the Analyze page.
# Defaults to http://localhost:5001 if unset.
VITE_ML_URL=

# Supabase project — from Settings → API. The anon key is public by design
# and safe to ship in the frontend bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
